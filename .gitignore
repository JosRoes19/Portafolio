cat > .gitignore << 'EOF'
# Dependencias
node_modules/

# Entorno
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Carpeta de build
dist/
build/
out/
.next/
public/videos/

# Archivos de caché y logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
*.tsbuildinfo

# Archivos del sistema
.DS_Store
Thumbs.db
EOF